class Greeter
# <- keyword.declaration.class.vibescript
#^^^^ keyword.declaration.class.vibescript
#     ^^^^^^^ entity.name.class.vibescript
  property name
# ^^^^^^^^ keyword.declaration.member.vibescript
#          ^^^^ variable.other.member.vibescript

  def self.build(name: String?) -> Greeter
# ^^^ keyword.declaration.function.vibescript
#     ^^^^ variable.language.self.vibescript
#         ^ punctuation.accessor.dot.vibescript
#          ^^^^^ entity.name.function.vibescript
#               ^ punctuation.section.group.begin.vibescript
#                ^^^^ variable.parameter.vibescript
#                    ^ punctuation.separator.annotation.type.vibescript
#                      ^^^^^^ support.class.vibescript
#                            ^ keyword.operator.optional.vibescript
#                             ^ punctuation.section.group.end.vibescript
#                               ^^ punctuation.separator.annotation.return-type.vibescript
#                                  ^^^^^^^ support.class.vibescript
    @name = :read
#   ^^^^^ variable.other.member.vibescript
#         ^ keyword.operator.assignment.vibescript
#           ^^^^^ constant.other.symbol.vibescript
    @@count += 1
#   ^^^^^^^ variable.other.class.vibescript
#           ^^ keyword.operator.assignment.augmented.vibescript
#              ^ constant.numeric.integer.vibescript
    "line\nnext"
#   ^ punctuation.definition.string.begin.vibescript
#    ^^^^ string.quoted.double.vibescript
#        ^^ constant.character.escape.vibescript
#              ^ punctuation.definition.string.end.vibescript
    "oops\q"
#        ^^ constant.character.escape.vibescript
  end
# ^^^ keyword.control.block.vibescript
end

private def secret
# <- keyword.declaration.visibility.vibescript
#       ^^^ keyword.declaration.function.vibescript
#           ^^^^^^ entity.name.function.vibescript
  42
end

export def exposed(value)
